import { parseYouTubeId, qs } from './utils.js';

let ytApiReady = false;
let ytApiPromise = null;

function loadYouTubeApi() {
  if (ytApiReady) return Promise.resolve();
  if (ytApiPromise) return ytApiPromise;

  ytApiPromise = new Promise((resolve) => {
    if (window.YT && window.YT.Player) { ytApiReady = true; resolve(); return; }
    window.onYouTubeIframeAPIReady = () => { ytApiReady = true; resolve(); };
    const tag = document.createElement('script');
    tag.src = 'https://www.youtube.com/iframe_api';
    document.head.appendChild(tag);
  });

  return ytApiPromise;
}

export class YouTubePreview {
  constructor({ urlInput, startHms, endHms, thumbContainer, thumbnailImg, playerWrap, playBtn, statusEl }) {
    this.urlInput = urlInput;
    this.startHms = startHms;
    this.endHms = endHms;
    this.thumbContainer = thumbContainer;
    this.thumbnailImg = thumbnailImg;
    this.playerWrap = playerWrap;
    this.playBtn = playBtn;
    this.statusEl = statusEl;

    this.player = null;
    this.currentVideoId = '';
    this.endCheckInterval = null;

    this.bind();
  }

  bind() {
    this.urlInput?.addEventListener('input', () => this.updateThumbnail());
    this.playBtn?.addEventListener('click', () => this.playSegment());
    this.updateThumbnail();
  }

  getStartSeconds() { return this.startHms ? this.startHms() : 0; }
  getEndSeconds() { return this.endHms ? this.endHms() : 12; }

  updateThumbnail() {
    const url = this.urlInput?.value?.trim() || '';
    const videoId = parseYouTubeId(url);

    if (!videoId) {
      if (this.thumbnailImg) this.thumbnailImg.classList.add('hidden');
      if (this.playBtn) this.playBtn.classList.add('hidden');
      if (this.playerWrap) { this.playerWrap.classList.add('hidden'); this.playerWrap.innerHTML = ''; }
      if (this.statusEl) this.statusEl.textContent = 'Paste a YouTube link to preview the selected segment.';
      this.destroyPlayer();
      return;
    }

    this.currentVideoId = videoId;

    // Show thumbnail
    if (this.thumbnailImg) {
      this.thumbnailImg.src = `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`;
      this.thumbnailImg.onerror = () => {
        this.thumbnailImg.src = `https://img.youtube.com/vi/${videoId}/hqdefault.jpg`;
      };
      this.thumbnailImg.classList.remove('hidden');
    }
    if (this.playBtn) this.playBtn.classList.remove('hidden');
    if (this.playerWrap) this.playerWrap.classList.add('hidden');
    if (this.statusEl) this.statusEl.textContent = 'Thumbnail loaded. Press play to preview the segment.';
  }

  async playSegment() {
    if (!this.currentVideoId) return;

    const startSeconds = this.getStartSeconds();
    const endSeconds = Math.max(startSeconds + 1, this.getEndSeconds());

    // Hide thumbnail, show player
    if (this.thumbnailImg) this.thumbnailImg.classList.add('hidden');
    if (this.playBtn) this.playBtn.classList.add('hidden');
    if (this.playerWrap) this.playerWrap.classList.remove('hidden');

    await loadYouTubeApi();

    if (this.player) {
      this.player.loadVideoById({ videoId: this.currentVideoId, startSeconds, endSeconds });
      this.startEndCheck(endSeconds);
      return;
    }

    // Create a container div for the player
    const playerId = `yt-player-${Date.now()}`;
    this.playerWrap.innerHTML = `<div id="${playerId}"></div>`;

    this.player = new window.YT.Player(playerId, {
      videoId: this.currentVideoId,
      playerVars: {
        autoplay: 1, start: startSeconds, end: endSeconds,
        rel: 0, playsinline: 1, modestbranding: 1, controls: 1
      },
      events: {
        onReady: () => {
          this.player.seekTo(startSeconds, true);
          this.player.playVideo();
          this.startEndCheck(endSeconds);
          if (this.statusEl) this.statusEl.textContent = `Playing segment ${this.formatTime(startSeconds)} → ${this.formatTime(endSeconds)}`;
        },
        onStateChange: (event) => {
          if (event.data === window.YT.PlayerState.ENDED || event.data === window.YT.PlayerState.PAUSED) {
            this.onSegmentEnd();
          }
        }
      }
    });
  }

  startEndCheck(endSeconds) {
    this.clearEndCheck();
    this.endCheckInterval = setInterval(() => {
      if (!this.player || typeof this.player.getCurrentTime !== 'function') return;
      if (this.player.getCurrentTime() >= endSeconds) {
        this.onSegmentEnd();
      }
    }, 250);
  }

  clearEndCheck() {
    if (this.endCheckInterval) { clearInterval(this.endCheckInterval); this.endCheckInterval = null; }
  }

  onSegmentEnd() {
    this.clearEndCheck();
    if (this.player && typeof this.player.pauseVideo === 'function') {
      this.player.pauseVideo();
    }
    // Hide player, show thumbnail again
    if (this.playerWrap) this.playerWrap.classList.add('hidden');
    if (this.thumbnailImg) this.thumbnailImg.classList.remove('hidden');
    if (this.playBtn) this.playBtn.classList.remove('hidden');
    if (this.statusEl) this.statusEl.textContent = 'Segment preview complete. Press play to replay.';
  }

  destroyPlayer() {
    this.clearEndCheck();
    if (this.player && typeof this.player.destroy === 'function') {
      try { this.player.destroy(); } catch {}
    }
    this.player = null;
    this.currentVideoId = '';
  }

  formatTime(seconds) {
    const s = Math.floor(seconds);
    const h = Math.floor(s / 3600);
    const m = Math.floor((s % 3600) / 60);
    const sec = s % 60;
    return [h, m, sec].map(v => String(v).padStart(2, '0')).join(':');
  }
}
